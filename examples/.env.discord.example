# discord_bot.py で使う環境変数。 examples/.env.discord にコピーして編集する。
#   cp examples/.env.discord.example examples/.env.discord

# Discord Developer Portal で作った Bot のトークン
DISCORD_TOKEN=

# 反映を即時化したい guild の ID (Developer Mode で右クリック → Copy ID)。
# 省略した場合はグローバル sync になり、コマンドが見えるまで最大 1 時間。
DISCORD_GUILD_ID=

# 母艦サーバの URL。CoreS3 用と同じ LAN IP でよい
STACKCHAN_URL=http://192.168.1.42:8000

# 母艦 server/.env の ENQUEUE_TOKEN と同じ値
STACKCHAN_ENQUEUE_TOKEN=

# HTTP タイムアウト秒。LLM 経由 (/enqueue via_llm=true) は遅いので少し長めに
STACKCHAN_TIMEOUT_S=60
