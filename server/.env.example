# =====================================================
#  母艦の設定。 .env にコピーして編集
#   cp .env.example .env
# =====================================================

# ---- TTS backend 選択 ----
# irodori  = CUDA in-process (Irodori-TTS-Lite, WSL2 / NVIDIA GPU 必須)
# voicevox = HTTP 経由 (Mac mini など、docs/setup-macmini.md 参照)
TTS_BACKEND=irodori

# ---- Whisper (STT) ----
# tiny / base / small / medium / large-v3
WHISPER_MODEL=small
WHISPER_DEVICE=cuda       # cuda / cpu / auto。Mac mini なら auto か cpu
WHISPER_LANGUAGE=ja

# ---- Ollama (LLM) ----
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b   # 日本語の出が素直なものを推奨
OLLAMA_TIMEOUT_S=60
OLLAMA_TEMPERATURE=0.7
OLLAMA_NUM_PREDICT=200
# 直近の往復をいくつ保持するか
HISTORY_TURNS=6
# メモリ上に保持する会話セッション数の上限
MAX_SESSIONS=16

# ---- Irodori-TTS-Lite (TTS_BACKEND=irodori 用) ----
IRODORI_DEVICE=cuda
# 参照音声 WAV のパス。空なら voice-design checkpoint (--no-ref 相当) を使う
IRODORI_REF_WAV=
# Ampere 以降なら fp16 が速い。1 = fp16 / 0 = fp32
IRODORI_FORCE_FP16=1
# チェックポイント。空なら HuggingFace から auto-download
IRODORI_CHECKPOINT=

# ---- VOICEVOX (TTS_BACKEND=voicevox 用) ----
VOICEVOX_HOST=http://127.0.0.1:50021
# 話者ID。3=ずんだもん(ノーマル), 8=春日部つむぎ, 2=四国めたん(ノーマル) など
VOICEVOX_SPEAKER=3

# ---- サーバ ----
# ※ ここの SERVER_HOST は **uvicorn の bind アドレス**。
#   `0.0.0.0` のままで LAN 内の他マシン (CoreS3 など) から到達できる。
#   CoreS3 側が接続するアドレスは `firmware/include/config.h` の SERVER_HOST 側で
#   母艦 PC/Mac の **LAN IP** を指定する (両者は別物なので混同しないこと)。
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info
# /chat で受け付ける WAV の最大サイズ。既定 2MiB は 16kHz/16bit/mono で約65秒分
MAX_AUDIO_BYTES=2097152

# ---- 定期発話 / 外部 push ----
# 1 で起動時にスケジューラを始動。0 だと scheduler 無効 (/pull と /enqueue は使える)
SCHEDULE_ENABLED=0
# cron トリガ定義 (schedule.json.example を参考に schedule.json を作る)
SCHEDULE_FILE=schedule.json
# 発話キューに溜められる最大件数
QUEUE_MAX_SIZE=16

# ---- TTS 起動時 pre-warm ----
# 1 で起動直後にダミー合成 1 回。初回 /chat の遅延を消す。0 で無効化。
TTS_PREWARM=1
# pre-warm に使うテキスト (短いほど早い)
TTS_PREWARM_TEXT=あ

# ---- 人格 (system prompt) の差し替え ----
# 指定したテキストファイルの内容が system prompt として使われる。
# 未指定なら server/persona.py の DEFAULT_SYSTEM_PROMPT が使われる。
# 反映には uvicorn の再起動が必要。
# PERSONA_FILE=./persona_custom.txt
