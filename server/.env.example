# =====================================================
#  母艦 (Windows + WSL2 / Ubuntu) の設定。 .env にコピーして編集
#   cp .env.example .env
# =====================================================

# ---- Whisper (STT) ----
# tiny / base / small / medium / large-v3
# CUDA があるなら medium / large-v3 まで上げて良い
WHISPER_MODEL=small
WHISPER_DEVICE=cuda       # cuda / cpu / auto
WHISPER_LANGUAGE=ja

# ---- Ollama (LLM) ----
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b   # 日本語の出が素直なものを推奨
# 直近の往復をいくつ保持するか
HISTORY_TURNS=6

# ---- Irodori-TTS-Lite (TTS) ----
IRODORI_DEVICE=cuda
# 参照音声 WAV のパス。空なら voice-design checkpoint (--no-ref 相当) を使う
IRODORI_REF_WAV=
# Ampere 以降なら fp16 が速い。1 = fp16 / 0 = fp32
IRODORI_FORCE_FP16=1
# チェックポイント。空なら HuggingFace から auto-download
# (例: hf://kizuna-intelligence/Irodori-TTS-Lite-int4/<file> もしくはローカル絶対パス)
IRODORI_CHECKPOINT=

# ---- サーバ ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info
