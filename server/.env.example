# =====================================================
#  Mac mini 母艦の設定。 .env にコピーして編集
#   cp .env.example .env
# =====================================================

# ---- Whisper (STT) ----
# tiny / base / small / medium / large-v3
# Apple Silicon なら small か medium が体感ちょうど良い
WHISPER_MODEL=small
WHISPER_DEVICE=auto       # auto / cpu / cuda / metal
WHISPER_LANGUAGE=ja

# ---- Ollama (LLM) ----
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b   # 日本語の出が素直なものを推奨
# 直近の往復をいくつ保持するか
HISTORY_TURNS=6

# ---- VOICEVOX (TTS) ----
VOICEVOX_HOST=http://127.0.0.1:50021
# 話者ID。3=ずんだもん(ノーマル), 8=春日部つむぎ, 2=四国めたん(ノーマル) など
VOICEVOX_SPEAKER=3

# ---- サーバ ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info
