# =====================================================
#  母艦の設定。 .env にコピーして編集
#   cp .env.example .env
# =====================================================

# ---- TTS backend 選択 ----
# irodori  = CUDA in-process (Irodori-TTS-Lite, WSL2 / NVIDIA GPU 必須)
# voicevox = HTTP 経由 (Mac mini など、docs/setup-macmini.md 参照)
TTS_BACKEND=irodori

# ---- Whisper (STT) ----
# tiny / base / small / medium / large-v3
WHISPER_MODEL=small
WHISPER_DEVICE=cuda       # cuda / cpu / auto。Mac mini なら auto か cpu
WHISPER_LANGUAGE=ja

# ---- Ollama (LLM) ----
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b   # 日本語の出が素直なものを推奨
OLLAMA_TIMEOUT_S=60
OLLAMA_TEMPERATURE=0.7
OLLAMA_NUM_PREDICT=200
# 直近の往復をいくつ保持するか
HISTORY_TURNS=6
# メモリ上に保持する会話セッション数の上限
MAX_SESSIONS=16

# ---- Irodori-TTS-Lite (TTS_BACKEND=irodori 用) ----
IRODORI_DEVICE=cuda
# 参照音声 WAV のパス。空なら voice-design checkpoint (--no-ref 相当) を使う
IRODORI_REF_WAV=
# Ampere 以降なら fp16 が速い。1 = fp16 / 0 = fp32
IRODORI_FORCE_FP16=1
# チェックポイント。空なら HuggingFace から auto-download
IRODORI_CHECKPOINT=

# ---- VOICEVOX (TTS_BACKEND=voicevox 用) ----
VOICEVOX_HOST=http://127.0.0.1:50021
# 話者ID。3=ずんだもん(ノーマル), 8=春日部つむぎ, 2=四国めたん(ノーマル) など
VOICEVOX_SPEAKER=3

# ---- サーバ ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info
# /chat で受け付ける WAV の最大サイズ。既定 2MiB は 16kHz/16bit/mono で約65秒分
MAX_AUDIO_BYTES=2097152
