// ========================================================
//  Wi-Fi / サーバ / ハード設定
//  これを config.h にコピーして自分の環境に書き換える
//   cp config.h.example config.h
//  config.h は .gitignore で除外しておくこと
// ========================================================
#pragma once

// ---- Wi-Fi (USB中継が無い場合のフォールバック) -------------
// USB CDCで母艦へ接続している間は、以下のSSID/PASSとSERVER_HOSTは使わない。
// 一度USB対応ファームを焼けば、外出先ごとのWi-Fi設定・再書込みは不要。
static constexpr const char* WIFI_SSID = "your-ssid";
static constexpr const char* WIFI_PASS = "your-password";

// ---- 母艦 (FastAPI サーバ) ---------------------------------
// Wi-Fiフォールバックで使う母艦 PC / Mac の **LAN IP** を入れる。
//   ※ `localhost` / `127.0.0.1` は CoreS3 から見ると自分自身を指してしまうので不可。
//   ※ Windows なら `ipconfig | findstr IPv4`、macOS なら `ipconfig getifaddr en0` で確認。
//   ※ 母艦と CoreS3 は同じ Wi-Fi LAN に置くこと。
static constexpr const char* SERVER_HOST = "192.168.1.42";
static constexpr uint16_t    SERVER_PORT = 8000;
static constexpr const char* SERVER_PATH = "/chat";
// 定期発話 / 外部 push の取り出し (GET /pull?wait=...) は
// http_client.h の ChatClient::pull() がパスをハードコードしている。
// SCHEDULE_ENABLED=0 でも /pull 自体は有効 (キュー空時は 204 が返る)。

// セッション ID。会話履歴をサーバ側で保持したい場合に使う
static constexpr const char* SESSION_ID  = "stackchan-01";

// ---- 録音パラメータ -----------------------------------------
// Whisper が 16kHz mono を素直に食えるのでそろえる
static constexpr uint32_t MIC_SAMPLE_RATE = 16000;
static constexpr uint8_t  MIC_BITS        = 16;
static constexpr uint8_t  MIC_CHANNELS    = 1;
// 1 発話あたりの最大録音秒数 (PSRAM にバッファ確保)
static constexpr uint32_t MAX_REC_SECONDS = 10;

// ---- Wake word ---------------------------------------------
// 1 にすると Idle 中に短い音声片を母艦 /wake へ送り、ウェイクワード検出後に
// 通常の録音へ入る。タッチ / リモコンの push-to-talk は常に併用可能。
#define WAKE_WORD_ENABLED 0
static constexpr uint32_t WAKE_LISTEN_MS = 1800;
static constexpr uint32_t WAKE_POLL_INTERVAL_MS = 3500;
// ウェイクワード検出時に beep の代わりに「なぁに?」等の短い返事を再生する
// (母艦 /speak で合成し、PSRAM にキャッシュ。省略時 1)。
#define WAKE_REPLY_ENABLED 1

// ---- スピーカ -----------------------------------------------
static constexpr uint8_t  SPK_VOLUME = 180; // 0..255

// ---- RGB LED (WS2812C x12) ----------------------------------
// StackChan 基板の PY32 I/O expander (I2C 0x6F) 経由で制御するため、
// GPIO データピンの指定は不要。使わない場合は RGB_ENABLED を 0 にする。
#define RGB_ENABLED  1
#define RGB_NUM_LEDS 12

// ---- サーボ (首振り) ----------------------------------------
// SCS0009 シリアルサーボ x2。StackChan 基板経由で GPIO6/7 固定。
// サーボを使わない場合は SERVO_ENABLED を 0 にする。
#define SERVO_ENABLED 1
// ピン番号は servo_controller.h に固定 (GPIO6=TX, GPIO7=RX)
//
// 以下のサブフラグは省略時 0 (servo_controller.h の既定)。
// SERVO_ENABLED=1 だけでは Idle の微動しか動かないので、演出が欲しい場合は
// 個別に 1 にする。
// 状態別ポーズ (Listening=上向き / Thinking=右傾き / Speaking=頷き基点)
#define SERVO_STATE_MOTION_ENABLED 1
// スワイプ撫でで首振り、シェイクでよろけアニメ
#define SERVO_WAGGLE_ENABLED 1
// 発話 RMS (口パク) に連動した微小な頷き
#define SERVO_LIPSYNC_MOTION_ENABLED 1
// 発話冒頭に emote 連動の首の動き (joy=弾む頷き / sad=うつむき /
// surprised=ビクッと上向き / shy=もじもじ / sleepy=こっくり)
#define SERVO_EMOTE_MOTION_ENABLED 1

// ---- Idle レアイベント (鼻歌 / 伸び) ------------------------
// 2〜5 分放置されると、たまに鼻歌を歌ったり伸びをする (省略時 1)。
#define IDLE_EVENT_ENABLED 1
#define IDLE_EVENT_MIN_MS (2UL * 60 * 1000)
#define IDLE_EVENT_MAX_MS (5UL * 60 * 1000)

// ---- Power management ---------------------------------------
// 0: Idle 30分後はソフトSleepに入り、タッチ/リモコンで復帰できる。
// 1: 従来通り deep sleep に入る。環境によっては電源ボタン以外で復帰できない。
#define POWER_IDLE_DEEP_SLEEP_ENABLED 0
// Sleep 中に、たまに /speak 経由で寝息・寝言を再生する。
// 初回は入眠後 45〜150 秒、以後は 2〜6 分ごとのランダム間隔。
#define SLEEP_MURMUR_ENABLED 1
#define SLEEP_MURMUR_INITIAL_MIN_MS (45UL * 1000)
#define SLEEP_MURMUR_INITIAL_MAX_MS (150UL * 1000)
#define SLEEP_MURMUR_MIN_MS (2UL * 60 * 1000)
#define SLEEP_MURMUR_MAX_MS (6UL * 60 * 1000)

// ---- SAM2695 MIDI module ------------------------------------
// UART MIDI 音源をぶら下げる場合は 1 にする。MIDI は 31250 bps。
// TX だけ接続すれば発音できる。RX を使わない場合は -1 のままでよい。
// CoreS3 の Port C / UART Grove を使う場合は、実配線に合わせて TX/RX を調整する。
#define MIDI_SAM2695_ENABLED 0
#define MIDI_UART_TX_PIN 17
#define MIDI_UART_RX_PIN -1
// 0..127。SAM2695 が大きい場合は 24〜48 あたりから調整する。
#define MIDI_VOLUME 48
// MIDI 再生中、Idle 状態なら曲の拍に合わせて首を振る。
#define MIDI_DANCE_ENABLED 1
// 何小節ごとに縦うなずきを入れるか。0 で縦うなずきなし。
#define MIDI_DANCE_NOD_MEASURES 4

// ---- HTTP タイムアウト --------------------------------------
// STT + LLM + TTS の合計を待つ。GPU やモデルサイズに応じて調整する。
// 目安: MAX_REC_SECONDS * 1000 + LLM 最大 30000 + TTS 最大 15000。
static constexpr uint32_t HTTP_TIMEOUT_MS = 55000;

// ---- オフライン (kawaii 動作確認) 用テストモード ------------
// 1 にすると WiFi 接続 / サーバ ready 確認 / 定期 pull / 録音後 send を
// すべてスキップし、起動後すぐ Idle に入る。表情アニメ (まばたき / マイクロ
// 表情 / 押下時の驚き) を WiFi なしで実機確認したい時用。
// ボタン押下時は録音はするが、HTTP 送信はせず擬似的に「考えてる」表示 →
// ack beep → 笑顔 → Idle の流れになる。本番運用時は 0 に戻す。
#define OFFLINE_MODE 0
